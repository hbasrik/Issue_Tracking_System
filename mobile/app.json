{
  "expo": {
    "name": "Karea Mobile",
    "slug": "karea-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0B0F14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karea.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Attach optional photos when reporting issues."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0F14"
      },
      "package": "com.karea.mobile"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach optional photos when reporting issues."
        }
      ]
    ]
  }
}
