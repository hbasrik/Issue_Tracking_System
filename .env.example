# Application
APP_ENV=development
PORT=8080

# Database (matches docker-compose postgres service)
DATABASE_URL=postgres://karea:karea_secret@localhost:5432/karea?sslmode=disable

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Browser CORS allowlist (comma-separated). Default is Vite local dev.
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Web (optional overrides)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Mobile (optional overrides) — use LAN IP on a physical device, not localhost
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
